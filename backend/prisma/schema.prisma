generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String   @db.VarChar(100)
  email    String   @unique @db.VarChar(100)
  senha    String   @db.VarChar(255)
  criadoEm DateTime @default(now())
  @@map("usuarios")
}

model Cliente {
  id     Int     @id @default(autoincrement())
  nome   String  @db.VarChar(100)
  vendas Venda[]
  @@map("clientes")
}

model Sabor {
  id              Int             @id @default(autoincrement())
  nome            String          @db.VarChar(50)
  precoUnitario   Decimal         @db.Decimal(10, 2)
  ativo           Boolean         @default(true)
  rendimentoBase  Int?
  vendaSabores    VendaSabor[]
  producaoSabores ProducaoSabor[]
  receita         ReceitaItem[]
  @@map("sabores")
}

model Venda {
  id               Int          @id @default(autoincrement())
  quantidade       Int
  valor            Decimal      @db.Decimal(10, 2)
  desconto         Decimal      @default(0) @db.Decimal(10, 2)
  data             DateTime     @default(now())
  idempotencyKey   String?      @unique @db.VarChar(100)
  clienteId        Int
  cliente          Cliente      @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  sabores          VendaSabor[]
  @@index([clienteId])
  @@index([data])
  @@map("vendas")
}

model VendaSabor {
  id         Int     @id @default(autoincrement())
  vendaId    Int
  saborId    Int
  quantidade Int
  venda      Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  sabor      Sabor   @relation(fields: [saborId], references: [id])
  @@index([vendaId])
  @@index([saborId])
  @@map("venda_sabores")
}

model MateriaPrima {
  id           Int                        @id @default(autoincrement())
  nome         String                     @db.VarChar(100)
  unidadeBase  String                     @db.VarChar(10)
  ativo        Boolean                    @default(true)
  criadoEm     DateTime                   @default(now())
  receita      ReceitaItem[]
  movimentacoes MovimentacaoMateriaPrima[]
  custos       Custo[]
  @@map("materias_primas")
}

model ReceitaItem {
  id             Int          @id @default(autoincrement())
  saborId        Int
  materiaPrimaId Int
  quantidadeBase Decimal      @db.Decimal(10, 3)
  sabor          Sabor        @relation(fields: [saborId], references: [id], onDelete: Cascade)
  materiaPrima   MateriaPrima @relation(fields: [materiaPrimaId], references: [id])
  @@index([saborId])
  @@index([materiaPrimaId])
  @@map("receita_itens")
}

model MovimentacaoMateriaPrima {
  id             Int          @id @default(autoincrement())
  materiaPrimaId Int
  tipo           String       @db.VarChar(10)
  origem         String       @db.VarChar(20)
  quantidade     Decimal      @db.Decimal(10, 3)
  data           DateTime     @default(now())
  custoId        Int?
  producaoId     Int?
  observacao     String?      @db.VarChar(255)
  materiaPrima   MateriaPrima @relation(fields: [materiaPrimaId], references: [id])
  @@index([materiaPrimaId])
  @@index([custoId])
  @@index([producaoId])
  @@map("movimentacoes_materia_prima")
}

model Custo {
  id             Int           @id @default(autoincrement())
  nome           String        @db.VarChar(100)
  categoria      String        @default("Matéria Prima") @db.VarChar(50)
  quantidade     Decimal       @db.Decimal(10, 3)
  unidade        String        @db.VarChar(20)
  valorTotal     Decimal       @db.Decimal(10, 2)
  data           DateTime      @default(now())
  observacao     String?       @db.VarChar(255)
  materiaPrimaId Int?
  materiaPrima   MateriaPrima? @relation(fields: [materiaPrimaId], references: [id])
  @@index([data])
  @@index([materiaPrimaId])
  @@map("custos")
}

model Producao {
  id         Int             @id @default(autoincrement())
  data       DateTime        @default(now())
  observacao String?         @db.VarChar(255)
  sabores    ProducaoSabor[]
  @@index([data])
  @@map("producao")
}

model ProducaoSabor {
  id         Int      @id @default(autoincrement())
  producaoId Int
  saborId    Int
  quantidade Int
  producao   Producao @relation(fields: [producaoId], references: [id], onDelete: Cascade)
  sabor      Sabor    @relation(fields: [saborId], references: [id])
  @@index([producaoId])
  @@index([saborId])
  @@map("producao_sabores")
}
